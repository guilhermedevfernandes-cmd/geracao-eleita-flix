# Configuração da história — editado por history (uma vez por episódio).
# Carregado por todos os scripts. Não use espaços ao redor do "=".
TITLE="Daniel na Cova dos Leões"
SLUG="daniel-na-cova-dos-leoes"

# Voz do NARRADOR — ElevenLabs v3 (direto), "Lucas – Deep & Profound Narrator":
# grave, sereno e solene (tom "vovô contador de histórias" da linha madura 5-11 anos).
# Áudio v3 é gerado por gen-narr.sh via ../scripts/elevenlabs_audio.py (stability 1.0).
NARRATOR_VOICE="GIuLCSVfgJaUuh7hYOY8"

# Estilo visual fixo — colado no fim de TODO prompt de imagem (consistência total).
STYLE="Disney Pixar 3D animation style, soft cinematic lighting, warm color palette, expressive big eyes, family-friendly, highly detailed, 16:9"

# Parâmetros de geração
ASPECT="16:9"        # proporção (16:9 YouTube, 9:16 Shorts)
IMG_RES="2k"         # resolução Nano Banana Pro
CLIP_SECONDS=5       # duração-base do clipe (Kling 5s; assemble estica p/ casar a narração)

# Provider de geração: "higgsfield" (padrão atual) ou "kie" (API Kie.ai).
# Para usar KIE, exporte KIE_API_KEY no ambiente antes de rodar os scripts.
GEN_PROVIDER="${GEN_PROVIDER:-higgsfield}"
KIE_IMAGE_MODEL="${KIE_IMAGE_MODEL:-google/nanobanana2}"
KIE_VIDEO_MODEL="${KIE_VIDEO_MODEL:-kling-3.0/video}"
KIE_USAGE_LOG="${KIE_USAGE_LOG:-build/kie-usage.tsv}"

# Vídeo via Kling (higgsfield CLI) — gen-clips.sh anima cada frame
VIDEO_MODEL="kling3_0_turbo"   # kling3_0_turbo (rápido, 1080p) | kling3_0 | kling2_6
VIDEO_RES="1080p"              # 720p | 1080p (só turbo)
VIDEO_DUR=5                    # 5 ou 10 segundos

# Montagem (ffmpeg)
TAIL=0.5             # respiro em segundos após cada narração
BGMVOL=0.10          # volume da música de fundo (0..1) — suave sob narração
