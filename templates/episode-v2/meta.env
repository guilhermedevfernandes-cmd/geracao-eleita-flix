# Geração Eleita Flix — contrato de produção v2.
# Este arquivo é carregado pelos scripts zsh. Não use espaços ao redor de "=".
TITLE="__TITLE__"
SLUG="__SLUG__"

# Gate editorial: episódios para YouTube com cinco minutos reais.
LANGUAGE="pt-BR"
TARGET_DURATION=300
MIN_DURATION=285
MAX_DURATION=315
WORDS_PER_MINUTE=138
MIN_SCENES=34
MAX_SCENES=46
MIN_BEAT_SECONDS=2.0
MAX_BEAT_SECONDS=11.2

# Gates de riqueza narrativa e audiovisual.
MIN_VOICES=4
MIN_DIALOGUE_RATIO=0.25
MIN_ACTS=6
MIN_SHOT_VARIETY=8
MIN_VFX_RATIO=0.25
MIN_SFX_RATIO=0.70
MIN_IMAGE_PROMPT_CHARS=100
MIN_MOTION_PROMPT_CHARS=60

# Identidade visual: longa infantil 3D premium, sem imitar uma marca específica.
STYLE="premium stylized 3D biblical animated feature-film look, warm soft cinematic lighting, rounded family-friendly forms, physically based materials, rich grounded environmental storytelling, detailed foreground midground and background, global illumination, soft volumetric lighting, subtle film grain, coherent warm color script, ancient biblical world, no text, no watermark"
IMAGE_QUALITY="single decisive cinematic frame, intentional lens choice, strong silhouette, natural depth of field, anatomically coherent hands and faces, consistent wardrobe and proportions, production-quality color grading"
IMAGE_NEGATIVE="flat staging, empty background, generic centered composition, unrequested people, human silhouettes, faces or bodies in clouds and light, anthropomorphic deity, duplicate characters, cloned faces, extra limbs, deformed hands, inconsistent costume, modern clothing, smartphones, cameras, technology, astronauts, spacecraft, science-fiction props, unrelated fantasy heroes, plastic toy look, low detail, text, subtitles, logo, watermark"
MOTION_QUALITY="one continuous cinematic shot, clear subject action, motivated camera movement, realistic secondary motion in hair cloth water smoke and particles, stable identity, temporal consistency, no morphing, no duplicated characters, no jump cuts, no lip-sync audio"

# Mídia.
ASPECT="16:9"
IMG_RES="2k"
REF_ASPECT="3:4"
GEN_PROVIDER="openart"
OPENART_MCP_SERVER="${OPENART_MCP_SERVER:-openart}"
OPENART_PROJECT_ID="${OPENART_PROJECT_ID:-}"
OPENART_IMAGE_MODEL="${OPENART_IMAGE_MODEL:-nano-banana-2}"
OPENART_VIDEO_MODEL="${OPENART_VIDEO_MODEL:-kling-3-omni}"
OPENART_CONCURRENCY="${OPENART_CONCURRENCY:-8}"
VIDEO_RES="${VIDEO_RES:-1080p}"
VIDEO_DUR=10

# A montagem nunca deve mascarar uma fala longa com câmera lenta excessiva.
MAX_STRETCH=1.12
FPS=24
BGMVOL=0.12
SFXVOL=0.38
MASTER_LIMIT=0.95

# Trilha opcional gerada por ./gen-score.sh.
SCORE_PROMPT="warm orchestral biblical adventure for children, emotional strings, gentle woodwinds, hand percussion, moments of wonder and suspense, hopeful resolution, memorable but unobtrusive"
